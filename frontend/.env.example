# BlueFinWiki Frontend Environment Variables

# API Configuration
VITE_API_BASE_URL=http://localhost:3000
# Local-only escape hatch when running a production-mode bundle against localhost.
# Keep this false/omitted for real deployments.
VITE_ALLOW_LOCAL_API_IN_PROD=false

# AWS Cognito Configuration
VITE_COGNITO_USER_POOL_ID=your-user-pool-id
VITE_COGNITO_CLIENT_ID=your-client-id
VITE_COGNITO_REGION=us-east-1

# Cognito Domain for hosted UI (production)
# Used for login redirects; e.g., your-domain.auth.us-east-1.amazoncognito.com
VITE_COGNITO_DOMAIN=your-domain.auth.us-east-1.amazoncognito.com

# Redirect URI after Cognito login (must match App Client settings)
VITE_COGNITO_REDIRECT_URI=https://yourdomain.com/callback

# Local Development: Set to true to bypass authentication
# This allows you to test the app without Cognito configuration
# DO NOT use in production
VITE_DISABLE_AUTH=false
