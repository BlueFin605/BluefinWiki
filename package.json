{
  "name": "bluefinwiki",
  "version": "0.1.0",
  "private": true,
  "description": "BlueFinWiki - Family Wiki Platform",
  "workspaces": [
    "frontend",
    "backend",
    "infrastructure"
  ],
  "scripts": {
    "lint": "npm run lint --workspaces",
    "type-check": "npm run type-check --workspaces",
    "test": "npm run test --workspaces",
    "test:all": "npm run test:all --workspaces",
    "postinstall": "test \"$CI\" != true && husky install || true"
  },
  "devDependencies": {
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
