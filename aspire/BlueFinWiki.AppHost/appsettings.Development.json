{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Aspire.Hosting": "Information",
      "OpenTelemetry": "Information"
    }
  },
  "AllowedHosts": "*",
  "Dashboard": {
    "Otlp": {
      "EndpointUrl": "http://localhost:18889",
      "AuthMode": "Unsecured"
    },
    "Frontend": {
      "EndpointUrl": "http://localhost:15888",
      "AuthMode": "Unsecured"
    }
  },
  "ConnectionStrings": {
    "LocalStack": "http://localhost:4566",
    "MailHog": "smtp://localhost:1025"
  },
  "ServiceEndpoints": {
    "Backend": "http://localhost:3000",
    "Frontend": "http://localhost:5173",
    "LocalStack": "http://localhost:4566",
    "MailHogUI": "http://localhost:8025"
  },
  "AWS": {
    "Region": "us-east-1",
    "AccessKeyId": "test",
    "SecretAccessKey": "test",
    "S3": {
      "PagesBucket": "bluefinwiki-pages-local",
      "ExportsBucket": "bluefinwiki-exports-local"
    },
    "DynamoDB": {
      "UsersTable": "bluefinwiki-user-profiles-local",
      "InvitationsTable": "bluefinwiki-invitations-local",
      "CommentsTable": "bluefinwiki-comments-local",
      "PageLinksTable": "bluefinwiki-page-links-local",
      "ActivityLogTable": "bluefinwiki-activity-log-local",
      "SiteConfigTable": "bluefinwiki-site-config-local"
    }
  },
  "OpenTelemetry": {
    "ServiceName": "BlueFinWiki",
    "ServiceVersion": "1.0.0",
    "EnableTracing": true,
    "EnableMetrics": true,
    "EnableLogging": true
  }
}
