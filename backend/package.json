{
  "name": "@bluefinwiki/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --enable-source-maps --watch --import tsx src/local-server.ts",
    "dev:debug": "node --enable-source-maps --inspect --watch --import tsx src/local-server.ts",
    "build": "tsc",
    "lint": "eslint . --ext ts --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit",
    "test": "vitest run --no-isolate",
    "test:watch": "vitest",
    "test:integration": "node --max-old-space-size=8192 ../node_modules/vitest/vitest.mjs run --config vitest.integration.config.ts",
    "test:all": "vitest run && vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1022.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.984.0",
    "@aws-sdk/client-dynamodb": "^3.511.0",
    "@aws-sdk/client-s3": "^3.511.0",
    "@aws-sdk/client-s3vectors": "^3.1022.0",
    "@aws-sdk/client-ses": "^3.511.0",
    "@aws-sdk/lib-dynamodb": "^3.511.0",
    "@aws-sdk/s3-request-presigner": "^3.511.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "aws-jwt-verify": "^5.1.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "fuse.js": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@smithy/util-stream": "^4.5.11",
    "@types/aws-lambda": "^8.10.134",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.17",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.0.1",
    "@typescript-eslint/parser": "^7.0.1",
    "aws-sdk-client-mock": "^4.0.0",
    "eslint": "^8.56.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2"
  }
}
