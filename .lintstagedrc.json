{
  "*": "echo 'Running pre-commit hooks...'",
  "*.{ts,tsx}": [
    "eslint --fix --max-warnings 0"
  ],
  "frontend/**/*.{ts,tsx}": [
    "bash -c 'tsc --noEmit --project frontend/tsconfig.json'"
  ],
  "backend/**/*.ts": [
    "bash -c 'tsc --noEmit --project backend/tsconfig.json'"
  ],
  "infrastructure/**/*.ts": [
    "bash -c 'tsc --noEmit --project infrastructure/tsconfig.json'"
  ]
}
